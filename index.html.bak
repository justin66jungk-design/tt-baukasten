/* Fallback fuer Browser ohne Clipboard API (execCommand deprecated, letztes Mittel) */
function fallbackCopy(txt){const ta=document.createElement("textarea");ta.value=txt;ta.style.position="fixed";ta.style.opacity="0";document.body.appendChild(ta);ta.select();try{document.execCommand("copy");toast("Plan kopiert");}catch(e){prompt("Zum Kopieren: Strg/Cmd+C druecken",txt);}ta.remove();}

/* Backup */
/* expBtn binding moved to unified exportBackup() below */

/* ============ BACKUP-IMPORT MIT SCHEMA-VALIDIERUNG (V0.10.1) ============
   Validiert eingehende Backups: Array-Check, Pflichtfelder, partieller Import. */
function validateAndImportBackup(d){
  const results={history:null,custom:null,settings:null,warnings:[]};

  /* 1. history validieren */
  if(d.history!==undefined){
    if(!Array.isArray(d.history)){
      results.warnings.push("history ist kein Array – ignoriert");
    } else {
      const valid=d.history.filter(entry=>{
        if(!entry||typeof entry!=="object")return false;
        if(typeof entry.date!=="string"||!/^\d{4}-\d{2}-\d{2}$/.test(entry.date))return false;
        if(!entry.sel||typeof entry.sel!=="object")return false;
        return true;
      });
      const skipped=d.history.length-valid.length;
      if(skipped>0)results.warnings.push(skipped+" Einträge übersprungen (ungültiges Format)");
      results.history=valid;
    }
  }

  /* 2. custom validieren */
  if(d.custom!==undefined){
    if(!Array.isArray(d.custom)){
      results.warnings.push("custom ist kein Array – ignoriert");
    } else {
      const valid=d.custom.filter(ex=>ex&&typeof ex==="object"&&ex.id&&ex.mod&&ex.title);
      const skipped=d.custom.length-valid.length;
      if(skipped>0)results.warnings.push(skipped+" eigene Übungen übersprungen (Pflichtfelder fehlen)");
      results.custom=valid;
    }
  }

  /* 3. settings validieren – unkritisch, defaults greifen */
  if(d.settings&&typeof d.settings==="object"){
    results.settings=d.settings;
  } else if(d.settings!==undefined){
    results.warnings.push("settings ungültig – ignoriert");
  }

  return results;
}

function applyImportResults(results,onDone){
  let imported=0;
  if(results.history!==null){setHistory(results.history);imported+=results.history.length;}
  if(results.custom!==null){custom=results.custom;lsSet("ttk_custom",custom);imported+=results.custom.length;}
  if(results.settings!==null){
    SETTINGS=Object.assign({club:"TV Bonn-Geislar",budgets:{...DEFAULT_BUDGETS},weights:{...DEFAULT_WEIGHTS}},results.settings);
    SETTINGS.budgets=Object.assign({...DEFAULT_BUDGETS},SETTINGS.budgets||{});
    SETTINGS.weights=Object.assign({...DEFAULT_WEIGHTS},SETTINGS.weights||{});
    saveSettings();
  }
  const warnStr=results.warnings.length?" ("+results.warnings.join("; ")+")":"";
  if(imported>0||results.settings!==null){
    toast("Backup importiert"+warnStr);
  } else {
    toast("Import: Keine gültigen Daten gefunden"+warnStr);
  }
  if(onDone)onDone();
}

function handleImportFile(file,onDone){
  if(!file)return;
  const r=new FileReader();
  r.onload=()=>{
    let d;
    try{d=JSON.parse(r.result);}
    catch(err){toast("Import fehlgeschlagen: Datei ist kein gültiges JSON.");return;}
    if(!d||typeof d!=="object"||Array.isArray(d)){
      toast("Import fehlgeschlagen: Unbekanntes Dateiformat.");
      return;
    }
    const results=validateAndImportBackup(d);
    applyImportResults(results,onDone);
  };
  r.onerror=()=>toast("Import fehlgeschlagen: Datei konnte nicht gelesen werden.");
  r.readAsText(file);
}
$("#impBtn").onclick=()=>$("#impFile").click();
$("#impFile").addEventListener("change",e=>{
  handleImportFile(e.target.files[0],()=>{render();initSettingsTab();});
  e.target.value="";
});
