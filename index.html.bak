  catMod=mod;catFilter=null;
  document.getElementById("catTitle").textContent="Katalog · "+MODS[mod].name;
  document.getElementById("catSearch").value="";
  renderCatFilters();renderCatalog();
  document.getElementById("catSheetBg").classList.add("open");
}

// Close on backdrop click (mobile)
document.getElementById("catSheetBg").addEventListener("click",e=>{
  if(e.target===document.getElementById("catSheetBg")) document.getElementById("catSheetBg").classList.remove("open");
});

/* ---- Auswerten-Sub aktualisieren ---- */
function updateAuswertenSub(){
  const el=document.getElementById("auswerten-sub");
  if(el) el.textContent="Trainingsanalyse für "+(SETTINGS.club||"TV Bonn-Geislar");
}

/* ---- Initial ---- */
updateAuswertenSub();


/* ================================================================
   TT-BAUKASTEN V0.10.3 — MATCH-MODUS + SPIELERPROFILE
   ================================================================ */

/* ============ SPIELERPROFILE ============ */
let players = lsGet("ttk_players", []);
function savePlayers() { lsSet("ttk_players", players); }
function playerById(id) { return players.find(p => p.id === id); }
function nextPlayerId() {
  const nums = players.map(p => parseInt((p.id || "p_0").replace("p_", "")) || 0);
  const max = nums.length ? Math.max(...nums) : 0;
  return "p_" + String(max + 1).padStart(3, "0");
}

function renderPlayerListSettings() {
  const el = document.getElementById("playerListSettings"); if (!el) return;
  const addBtn = document.getElementById("addPlayerBtn");
  if (addBtn) addBtn.style.display = players.length >= 10 ? "none" : "";
  if (!players.length) {
    el.innerHTML = `<div class="stat-empty" style="padding:8px 0">Noch keine Profile angelegt.</div>`;
    return;
  }
  el.innerHTML = players.map(p => `
    <div class="player-item">
      <div class="pi-info">
        <div class="pi-name">${esc(p.name)}</div>
        <div class="pi-meta">${esc(p.hand === "L" ? "Linkshand" : "Rechtshand")}${p.birthyear ? " · *" + p.birthyear : ""}${p.style ? " · " + p.style : ""}${p.matchHistory?.length ? " · " + p.matchHistory.length + " Match(es)" : ""}</div>
      </div>
      <div class="pi-actions">
        <button class="btn ghost" style="padding:5px 10px;font-size:12.5px" data-editplayer="${esc(p.id)}">Bearbeiten</button>
      </div>
    </div>`).join("");
}

function openPlayerModal(p) {
  document.getElementById("playerModalTitle").textContent = p ? "Profil bearbeiten" : "Neues Profil";
  document.getElementById("pmId").value = p ? p.id : "";
  document.getElementById("pmName").value = p ? p.name : "";
  document.getElementById("pmHand").value = p ? (p.hand || "R") : "R";
  document.getElementById("pmBirthyear").value = p ? (p.birthyear || "") : "";
  document.getElementById("pmStyle").value = p ? (p.style || "") : "";
  const delBtn = document.getElementById("pmDelete");
  if (delBtn) delBtn.style.display = p ? "" : "none";
  document.getElementById("playerModal").classList.add("open");
}

function savePlayerModal() {
  const id = document.getElementById("pmId").value || nextPlayerId();
  const name = document.getElementById("pmName").value.trim();
  if (!name) { toast("Name ist Pflichtfeld"); return; }
  const existing = players.find(p => p.id === id);
  if (existing) {
    existing.name = name;
    existing.hand = document.getElementById("pmHand").value;
    existing.birthyear = parseInt(document.getElementById("pmBirthyear").value) || null;
    existing.style = document.getElementById("pmStyle").value.trim();
  } else {
    if (players.length >= 10) { toast("Max. 10 Profile erreicht"); return; }
    players.push({
      id, name,
      hand: document.getElementById("pmHand").value,
      birthyear: parseInt(document.getElementById("pmBirthyear").value) || null,
      style: document.getElementById("pmStyle").value.trim(),
      matchHistory: []
    });
  }
  savePlayers();
  document.getElementById("playerModal").classList.remove("open");
  renderPlayerListSettings();
  renderMatchPlayerDropdown();
  toast("Profil gespeichert");
}

function deletePlayerModal() {
  const id = document.getElementById("pmId").value; if (!id) return;
  if (!confirm("Profil löschen? Die gesamte Match-History geht verloren.")) return;
  players = players.filter(p => p.id !== id);
  savePlayers();
  document.getElementById("playerModal").classList.remove("open");
  renderPlayerListSettings();
  renderMatchPlayerDropdown();
  toast("Profil gelöscht");
}

document.getElementById("addPlayerBtn").onclick = () => openPlayerModal(null);
document.getElementById("pmSave").onclick = savePlayerModal;
document.getElementById("pmDelete").onclick = deletePlayerModal;
document.getElementById("playerModalClose").onclick = () => document.getElementById("playerModal").classList.remove("open");
document.getElementById("playerModal").addEventListener("click", e => {
  if (e.target === document.getElementById("playerModal")) document.getElementById("playerModal").classList.remove("open");
});
document.addEventListener("click", e => {
  const t = e.target.closest("[data-editplayer]");
  if (t) { openPlayerModal(playerById(t.dataset.editplayer)); }
});

/* ============ MATCH-STATE ============ */
let matches = lsGet("ttk_matches", []);
function saveMatches() { lsSet("ttk_matches", matches); }

let activeMatch = null;
/* activeMatch shape:
   { id, date, tournament, playerA:{profileId,name}, playerB:{name},
     format, sets[], result,
     firstServerSet1: "A"|"B"   ← wer in Satz 1 zuerst aufschlägt
   }
   set shape: { rallies:[{winner,chip}], score:[0,0], coachNote:"", briefing:null }
*/

let _pendingChip = null;

/* ============ AUFSCHLAG-LOGIK (ITTF 2.13.6) ============
   - Innerhalb eines Satzes: alle 2 Punkte wechseln; bei 10:10 nach jedem Punkt
   - Satzwechsel: wer in Satz N zuerst aufschlägt → schlägt in Satz N+1 NICHT zuerst auf
   - firstServerSet1 wird beim Match-Start festgelegt */

function firstServerOfSet(setIndex) {
  // Wer schlägt im Satz setIndex (0-basiert) zuerst auf?
  const base = activeMatch.firstServerSet1; // "A" oder "B"
  // Wechselt nach jedem Satz (ITTF 2.13.6)
  return (setIndex % 2 === 0) ? base : (base === "A" ? "B" : "A");
}

function currentServer(setIndex, totalPoints) {
  // Innerhalb eines Satzes: alle 2 Punkte wechseln
  // Bei 10:10 nach jedem Punkt (deuce)
  const cs = activeMatch.sets[setIndex];
  if (!cs) return firstServerOfSet(setIndex);
  const a = cs.score[0], b = cs.score[1];
  const isDeuce = a >= 10 && b >= 10;
  const firstServer = firstServerOfSet(setIndex);
  let serverIndex; // Anzahl der Wechsel
  if (isDeuce) {
    // Nach 10:10: beide hatten je 10 Aufschläge in 2er-Blöcken = 10 Blöcke
    // Ab Deuce: jeder Punkt = 1 Wechsel
    const deucePoints = (a - 10) + (b - 10); // Punkte seit Deuce
    serverIndex = 10 + deucePoints; // 10 Blöcke à 2 + einzelne
    // Jeder Block à 1 ab Deuce
    const deuceBlocks = deucePoints; // jeder Punkt = neuer Block
    serverIndex = 10 + deuceBlocks;
  } else {
    // Vor Deuce: Block von je 2 Punkten
    serverIndex = Math.floor(totalPoints / 2);
  }
  const isFirstServer = (serverIndex % 2 === 0);
  return isFirstServer ? firstServer : (firstServer === "A" ? "B" : "A");
}

function getCurrentServer() {
  if (!activeMatch) return "A";
  const setIdx = activeMatch.sets.length - 1;
  const cs = currentSet();
  const total = cs.score[0] + cs.score[1];
  return currentServer(setIdx, total);
}

/* ============ MATCH SETUP RENDER ============ */
function renderMatchPlayerDropdown() {
  const sel = document.getElementById("matchPlayerASelect"); if (!sel) return;
  sel.innerHTML = `<option value="guest">Gast (kein Profil)</option>` +
    players.map(p => `<option value="${esc(p.id)}">${esc(p.name)}</option>`).join("");
  toggleGuestInput();
}

function toggleGuestInput() {
  const sel = document.getElementById("matchPlayerASelect");
  const guestDiv = document.getElementById("matchPlayerAGuest");
  if (!sel || !guestDiv) return;
  guestDiv.style.display = sel.value === "guest" ? "" : "none";
}
document.getElementById("matchPlayerASelect").addEventListener("change", toggleGuestInput);

/* ============ MATCH START ============ */
document.getElementById("matchStartBtn").onclick = function () {
  const selA = document.getElementById("matchPlayerASelect").value;
  let nameA, profileId = null;
  if (selA === "guest") {
    nameA = document.getElementById("matchPlayerAName").value.trim() || "Spieler A";
  } else {
    profileId = selA;
    nameA = playerById(selA)?.name || "Spieler A";
  }
  const nameB = document.getElementById("matchPlayerBName").value.trim() || "Gegner";
  const format = parseInt(document.getElementById("matchFormat").value) || 3;
  const tournament = document.getElementById("matchTournament").value.trim();

  activeMatch = {
    id: "m_" + Date.now(),
    date: today(),
    tournament,
    playerA: { profileId, name: nameA },
    playerB: { name: nameB },
    format,
    firstServerSet1: "A", // default — user can change in live screen before first point
    sets: [],
    result: null
  };
  _pendingChip = null;
  startNewSet();

  // Update serve toggle labels
  const btnA = document.getElementById("serveToggleA");
  const btnB = document.getElementById("serveToggleB");
  if (btnA) btnA.textContent = nameA;
  if (btnB) btnB.textContent = nameB;
  updateServeToggleUI();
  updateServeToggleRowVisibility();

  renderMatchLive();
  document.getElementById("matchSetup").style.display = "none";
  document.getElementById("matchLive").style.display = "";
  document.getElementById("matchFinish").style.display = "none";
};

function startNewSet() {
  activeMatch.sets.push({ rallies: [], score: [0, 0], coachNote: "", briefing: null });
}

function currentSet() { return activeMatch.sets[activeMatch.sets.length - 1]; }

/* ============ CHIP KONTEXT-LOGIK (V0.10.4) ============
   Welche Chips sind sinnvoll hängt vom aktuellen Aufschläger ab:
   
   A schlägt auf:
     AS+  ✓  (Ass / Gegner-Rückschlag-Fehler → Punkt A)
     AS-  ✓  (Aufschlag-Fehler von A → Punkt B, automatisch)
     AN+  ✗  (A nimmt an? A hat doch Aufschlag — keinen Sinn)
     AN-  ✗  (A nimmt an? — keinen Sinn)
     R+   ✓  (nach 2. Ball: Rallye gewonnen → Punkt A)
     R-   ✓  (nach 2. Ball: Rallye-Fehler → Punkt B, automatisch)
   
   B schlägt auf:
     AS+  ✗  (Aufschlag-Punkt für A? A hat keinen Aufschlag)
     AS-  ✗  (Aufschlag-Fehler von A? A schlägt nicht auf)
     AN+  ✓  (A nimmt an und gewinnt direkt → Punkt A, automatisch)
     AN-  ✓  (A macht Annahme-Fehler → Punkt B, automatisch)
     R+   ✓  
     R-   ✓  
   
   Chips die den Winner eindeutig bestimmen (Auto-Punkt):
     AS- → Punkt B automatisch
     AN+ → Punkt A automatisch  
     AN- → Punkt B automatisch
     R-  → Punkt B automatisch
     AS+ → Punkt A automatisch (Ass oder direkter Rückschlag-Fehler)
   
   Nur R+ erfordert noch manuellen Punkt-Button (Rally könnte theoretisch
   auch mit einem Fehler enden der dem anderen gehört). Wir zeigen aber
   trotzdem Auto-Punkt für R+ auf A, da der Chip "Rallye gewonnen" ja
   eindeutig A zuordnet. → alle Chips außer keinem sind Auto.
*/

const CHIP_CONTEXT = {
  // chip: { validWhenServer: "A"|"B"|"both", autoWinner: "A"|"B"|null }
  "AS+": { validWhen: "A",    autoWinner: "A" },
  "AS-": { validWhen: "A",    autoWinner: "B" },
  "AN+": { validWhen: "B",    autoWinner: "A" },
  "AN-": { validWhen: "B",    autoWinner: "B" },
  "R+":  { validWhen: "both", autoWinner: "A" },
  "R-":  { validWhen: "both", autoWinner: "B" },
};

/* ============ SERVE TOGGLE ============ */
function updateServeToggleUI() {
  if (!activeMatch) return;
  const btnA = document.getElementById("serveToggleA");
  const btnB = document.getElementById("serveToggleB");
  if (!btnA || !btnB) return;
  btnA.classList.toggle("active", activeMatch.firstServerSet1 === "A");
  btnB.classList.toggle("active", activeMatch.firstServerSet1 === "B");
}

function updateServeToggleRowVisibility() {
  if (!activeMatch) return;
  const row = document.getElementById("serveToggleRow"); if (!row) return;
  const totalRallies = activeMatch.sets.flatMap(s => s.rallies).length;
  row.style.display = totalRallies === 0 ? "" : "none";
  const label = row.querySelector(".stl");
  const satzNr = activeMatch.sets.length;
  if (label) label.textContent = `Aufschlag Satz ${satzNr}:`;
  const btnA = document.getElementById("serveToggleA");
  const btnB = document.getElementById("serveToggleB");
  if (btnA) btnA.textContent = activeMatch.playerA.name;
  if (btnB) btnB.textContent = activeMatch.playerB.name;
}

document.getElementById("serveToggleA").addEventListener("click", () => {
  if (!activeMatch || currentSet().rallies.length > 0) return;
  activeMatch.firstServerSet1 = "A";
  updateServeToggleUI(); renderMatchLive();
});
document.getElementById("serveToggleB").addEventListener("click", () => {
  if (!activeMatch || currentSet().rallies.length > 0) return;
  activeMatch.firstServerSet1 = "B";
  updateServeToggleUI(); renderMatchLive();
});

/* ============ EXIT ============ */
document.getElementById("matchExitBtn").addEventListener("click", () => {
  if (!confirm("Match abbrechen? Alle aufgezeichneten Punkte gehen verloren.")) return;
  activeMatch = null; _pendingChip = null;
  document.getElementById("matchSetup").style.display = "";
  document.getElementById("matchLive").style.display = "none";
  document.getElementById("matchFinish").style.display = "none";
  renderMatchPlayerDropdown();
});

/* ============ LIVE RENDER ============ */
function renderMatchLive() {
  if (!activeMatch) return;
  const cs = currentSet();
  const nameA = activeMatch.playerA.name;
  const nameB = activeMatch.playerB.name;

  document.getElementById("liveNameA").childNodes[0].textContent = nameA + " ";
  document.getElementById("liveNameB").childNodes[0].textContent = nameB + " ";
  document.getElementById("pointNameA").textContent = nameA;
  document.getElementById("pointNameB").textContent = nameB;
  document.getElementById("chipPlayerName").textContent = nameA;
  const _titleEl = document.getElementById("liveMatchTitle");
  if (_titleEl) _titleEl.textContent = nameA + " vs " + nameB + (activeMatch.tournament ? " · " + activeMatch.tournament : "");
  document.getElementById("liveScoreA").textContent = cs.score[0];
  document.getElementById("liveScoreB").textContent = cs.score[1];

  const completedSets = activeMatch.sets.slice(0, -1);
  const setWinsA = completedSets.filter(s => s.score[0] > s.score[1]).length;
  const setWinsB = completedSets.filter(s => s.score[0] < s.score[1]).length;
  document.getElementById("liveSetInfo").textContent = `Satz ${activeMatch.sets.length}`;
  document.getElementById("liveSetWinsA").textContent = `${setWinsA} Satz${setWinsA !== 1 ? "e" : ""}`;
  document.getElementById("liveSetWinsB").textContent = `${setWinsB} Satz${setWinsB !== 1 ? "e" : ""}`;

  const server = getCurrentServer();
  const indA = document.getElementById("serveIndA");
  const indB = document.getElementById("serveIndB");
  if (indA) indA.style.display = server === "A" ? "" : "none";
  if (indB) indB.style.display = server === "B" ? "" : "none";

  updateServeToggleRowVisibility();
  updateServeToggleUI();

  // Chip states
  const infoEl = document.getElementById("autoPointInfo");
  const rallyHint = document.getElementById("rallyPointHint");
  const pointRow = document.getElementById("matchPointRow");
  const manualLabel = document.getElementById("manualPointLabel");
  const isRallyChip = _pendingChip === "R+" || _pendingChip === "R-";
  const isAutoChip = _pendingChip && !isRallyChip && CHIP_CONTEXT[_pendingChip];

  document.querySelectorAll(".match-chip").forEach(c => {
    const chip = c.dataset.chip;
    const ctx = CHIP_CONTEXT[chip];
    const isActive = chip === _pendingChip;
    const isDisabled = ctx && ctx.validWhen !== "both" && ctx.validWhen !== server;
    c.classList.remove("active", "ctx-disabled");
    if (isActive) c.classList.add("active");
    if (isDisabled && !isActive) c.classList.add("ctx-disabled");
  });

  if (isAutoChip) {
    const ctx = CHIP_CONTEXT[_pendingChip];
    document.getElementById("autoPointText").textContent = `→ Punkt geht an ${ctx.autoWinner === "A" ? nameA : nameB}`;
    document.getElementById("autoPointSub").textContent = chipDescription(_pendingChip, nameA, server);
    infoEl.classList.add("visible");
    rallyHint.classList.remove("visible");
    pointRow.classList.add("auto-mode");
    manualLabel.style.display = "none";
  } else if (isRallyChip) {
    infoEl.classList.remove("visible");
    rallyHint.classList.add("visible");
    pointRow.classList.remove("auto-mode");
    manualLabel.style.display = "none";
  } else {
    infoEl.classList.remove("visible");
    rallyHint.classList.remove("visible");
    pointRow.classList.remove("auto-mode");
    manualLabel.style.display = _pendingChip ? "none" : "";
  }

  const allRallies = activeMatch.sets.flatMap(s => s.rallies);
  document.getElementById("matchUndo").disabled = allRallies.length === 0;
}

function chipDescription(chip, nameA, server) {
  const nameB = activeMatch?.playerB?.name || "Gegner";
  switch(chip) {
    case "AS+": return `${nameA} macht Ass oder ${nameB} schlägt direkt ins Netz`;
    case "AS-": return `${nameA} macht Aufschlagfehler`;
    case "AN+": return `${nameA} gewinnt den Punkt direkt mit dem Return`;
    case "AN-": return `${nameA} macht Annahmefehler`;
    case "R+":  return `${nameA} gewinnt die Rallye — Punkt-Button wählen`;
    case "R-":  return `${nameA} macht Fehler in der Rallye — Punkt-Button wählen`;
    default: return "";
  }
}

/* ============ CHIP SELECTION ============ */
document.getElementById("matchChips").addEventListener("click", e => {
  const btn = e.target.closest("[data-chip]"); if (!btn) return;
  if (btn.classList.contains("ctx-disabled")) return;
  const chip = btn.dataset.chip;
  const prev = _pendingChip;
  _pendingChip = (prev === chip) ? null : chip;

  // Auto-chips: book immediately, no confirm needed
  const isRally = chip === "R+" || chip === "R-";
  if (_pendingChip && !isRally && CHIP_CONTEXT[_pendingChip]) {
    const winner = CHIP_CONTEXT[_pendingChip].autoWinner;
    // Flash score briefly then record
    const scoreEl = document.getElementById(winner === "A" ? "liveScoreA" : "liveScoreB");
    if (scoreEl) scoreEl.classList.add("score-flash");
    setTimeout(() => scoreEl && scoreEl.classList.remove("score-flash"), 300);
    recordPoint(winner);
    return;
  }
  renderMatchLive();
});

/* ============ PUNKT BUTTONS ============ */
document.getElementById("pointA").onclick = () => recordPoint("A");
document.getElementById("pointB").onclick = () => recordPoint("B");

function recordPoint(winner) {
  if (!activeMatch) return;
  const cs = currentSet();
  cs.rallies.push({ winner, chip: _pendingChip || null });
  if (winner === "A") cs.score[0]++;
  else cs.score[1]++;
  _pendingChip = null;

  if (isSetOver(cs.score[0], cs.score[1])) {
    handleSetEnd();
  } else {
    renderMatchLive();
  }
}

function isSetOver(a, b) {
  const maxP = Math.max(a, b);
  if (maxP < 11) return false;
  return Math.abs(a - b) >= 2;
}

function matchWinner() {
  if (!activeMatch) return null;
  const toWin = activeMatch.format === 5 ? 3 : 2;
  const winsA = activeMatch.sets.filter((s, i) => i < activeMatch.sets.length && s.score[0] > s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  const winsB = activeMatch.sets.filter((s, i) => i < activeMatch.sets.length && s.score[0] < s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  if (winsA >= toWin) return "A";
  if (winsB >= toWin) return "B";
  return null;
}

function handleSetEnd() {
  if (!activeMatch) return;
  const cs = currentSet();
  cs.briefing = buildSetBriefing(cs);

  // Satzpausen-Modal öffnen
  const satzNr = activeMatch.sets.length;
  document.getElementById("setPauseTitle").textContent = `Satzpause — Satz ${satzNr}`;
  document.getElementById("setPauseSubtitle").textContent =
    `${activeMatch.playerA.name} ${cs.score[0]}:${cs.score[1]} ${activeMatch.playerB.name}`;
  document.getElementById("setPauseNote").value = "";
  renderSetPauseStats(cs.briefing);

  // Verlust-Serie
  const lossWarnEl = document.getElementById("setPauseLossWarn");
  if (cs.briefing.longestLossSeries >= 3) {
    lossWarnEl.style.display = "";
    lossWarnEl.textContent = `⚠ Längste Verlustserie: ${cs.briefing.longestLossSeries} Punkte in Folge bei Stand ${cs.briefing.longestLossAt}`;
  } else {
    lossWarnEl.style.display = "none";
  }

  document.getElementById("setPauseModal").classList.add("open");
  renderMatchLive();
}

function renderSetPauseStats(b) {
  const el = document.getElementById("setPauseStats"); if (!el) return;
  function pct(v) { return isNaN(v) ? "–" : Math.round(v * 100) + "%"; }
  function color(v, good, ok) {
    if (isNaN(v)) return "var(--mut)";
    return v >= good ? "var(--kraft)" : v >= ok ? "var(--warm)" : "var(--red)";
  }
  el.innerHTML = `
    <div class="stat-cell">
      <div class="sc-lbl">Aufschlag-Effizienz</div>
      <div class="sc-val" style="color:${color(b.serveEff, .65, .45)}">${pct(b.serveEff)}</div>
      <div class="sc-sub">${b.servePlus + b.serveMinus} Aufschläge (${b.servePlus}+ / ${b.serveMinus}−)</div>
    </div>
    <div class="stat-cell">
      <div class="sc-lbl">Annahme-Stabilität</div>
      <div class="sc-val" style="color:${color(b.receiveStab, .65, .45)}">${pct(b.receiveStab)}</div>
      <div class="sc-sub">${b.receivePlus + b.receiveMinus} Annahmen (${b.receivePlus}+ / ${b.receiveMinus}−)</div>
    </div>
    <div class="stat-cell">
      <div class="sc-lbl">Rallye-Qualität</div>
      <div class="sc-val" style="color:${color(b.rallyQual, .6, .4)}">${pct(b.rallyQual)}</div>
      <div class="sc-sub">${b.rallyPlus + b.rallyMinus} Rallyes (${b.rallyPlus}+ / ${b.rallyMinus}−)</div>
    </div>
    <div class="stat-cell">
      <div class="sc-lbl">Druckpunkte (≥8:8)</div>
      <div class="sc-val" style="color:${color(b.pressurePerf, .55, .35)}">${b.pressureTotal ? pct(b.pressurePerf) : "–"}</div>
      <div class="sc-sub">${b.pressureWon}/${b.pressureTotal} gewonnen</div>
    </div>`;
}

document.getElementById("setPauseUndo").onclick = function () {
  if (!activeMatch) return;
  // Satzpausen-Modal schließen, letzten Punkt des aktuellen (gerade beendeten) Satzes rückgängig
  document.getElementById("setPauseModal").classList.remove("open");
  const cs = currentSet();
  if (cs.rallies.length > 0) {
    const last = cs.rallies.pop();
    if (last.winner === "A") cs.score[0]--;
    else cs.score[1]--;
    cs.briefing = null; // Briefing invalidieren
  }
  renderMatchLive();
};

document.getElementById("setPauseContinue").onclick = function () {
  if (!activeMatch) return;
  const cs = currentSet();
  cs.coachNote = document.getElementById("setPauseNote").value.trim();
  document.getElementById("setPauseModal").classList.remove("open");

  // Match-Ende prüfen
  const winner = matchWinner();
  if (winner) {
    finishMatch(winner);
  } else {
    startNewSet();
    renderMatchLive();
  }
};

/* ============ UNDO ============ */
document.getElementById("matchUndo").onclick = function () {
  if (!activeMatch) return;
  // Finde letzten Punkt – ggf. in vorherigem Satz (wenn aktueller Satz leer nach Satz-Ende)
  // Wir erlauben Undo nur innerhalb des aktuellen Satzes (Satzpausen-Modal ist dann schon weg)
  const cs = currentSet();
  if (cs.rallies.length === 0) {
    // Letzten Satz rückgängig → geht nur wenn kein Satzpausen-Modal gerade offen
    if (activeMatch.sets.length > 1) {
      activeMatch.sets.pop();
      const prev = currentSet();
      // Letzten Punkt aus vorherigem Satz entfernen
      if (prev.rallies.length) {
        const last = prev.rallies.pop();
        if (last.winner === "A") prev.score[0]--;
        else prev.score[1]--;
        prev.briefing = null;
      }
      renderMatchLive();
    }
    return;
  }
  const last = cs.rallies.pop();
  if (last.winner === "A") cs.score[0]--;
  else cs.score[1]--;
  renderMatchLive();
};

/* ============ MATCH FINISH ============ */
function finishMatch(winner) {
  if (!activeMatch) return;
  const setWinsA = activeMatch.sets.filter(s => s.score[0] > s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  const setWinsB = activeMatch.sets.filter(s => s.score[0] < s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  activeMatch.result = (winner === "A" ? activeMatch.playerA.name : activeMatch.playerB.name) +
    " " + setWinsA + ":" + setWinsB;

  // Profil-Verknüpfung
  if (activeMatch.playerA.profileId) {
    const p = playerById(activeMatch.playerA.profileId);
    if (p) {
      const keyStats = buildMatchKeyStats(activeMatch);
      const trainingFocus = deriveTrainingFocus(keyStats);
      const coachNotes = activeMatch.sets.filter(s => s.coachNote).map(s => s.coachNote).join(" | ");
      p.matchHistory = p.matchHistory || [];
      p.matchHistory.push({
        matchId: activeMatch.id,
        date: activeMatch.date,
        opponent: activeMatch.playerB.name,
        result: (winner === "A" ? "W " : "L ") + setWinsA + ":" + setWinsB,
        keyStats,
        trainingFocus,
        coachNotes
      });
      savePlayers();
    }
  }

  // Match speichern
  matches.push(JSON.parse(JSON.stringify(activeMatch)));
  saveMatches();

  // UI
  document.getElementById("matchLive").style.display = "none";
  document.getElementById("matchFinish").style.display = "";
  const winnerName = winner === "A" ? activeMatch.playerA.name : activeMatch.playerB.name;
  document.getElementById("finishEmoji").textContent = winner === "A" ? "🏆" : "💪";
  document.getElementById("finishTitle").textContent = `${winnerName} gewinnt!`;
  document.getElementById("finishSubtitle").textContent =
    `${activeMatch.playerA.name} ${setWinsA}:${setWinsB} ${activeMatch.playerB.name}` +
    (activeMatch.tournament ? ` · ${activeMatch.tournament}` : "");

  renderMatchReport("player");
}

/* ============ COACH-BOT: buildSetBriefing ============
   Chip-Logik (V0.10.3.1): Chips beschreiben IMMER eine Aktion/Situation von Spieler A.
   Der Punkt-Button sagt nur, wer den Punkt bekommt — unabhängig vom Chip.
   
   Zuordnungsmatrix:
   AS+  → Punkt an A  : Aufschlag-Effizienz +Plus
   AS-  → Punkt an B  : Aufschlag-Effizienz +Minus  (A macht AS-Fehler → B bekommt Punkt)
   AN+  → Punkt an A  : Annahme-Stabilität +Plus     (A nimmt gut an → A gewinnt Rally)
   AN-  → Punkt an B  : Annahme-Stabilität +Minus    (A macht AN-Fehler → B bekommt Punkt)  ← Nils-Fall
   R+   → Punkt an A  : Rallye-Qualität +Plus
   R-   → Punkt an B  : Rallye-Qualität +Minus       (A macht Rallye-Fehler → B bekommt Punkt)
   
   Die Zuordnung ist ausschließlich chip-basiert, nicht winner-basiert.
   Ohne Chip: Rally ohne Situationscode → zählt nicht zu den Kennzahlen. */

function buildSetBriefing(set) {
  const rallies = set.rallies;
  let servePlus = 0, serveMinus = 0;
  let receivePlus = 0, receiveMinus = 0;
  let rallyPlus = 0, rallyMinus = 0;
  let pressureWon = 0, pressureTotal = 0;
  let score = [0, 0];
  let lossStreak = 0, maxLossStreak = 0, lossAt = "";

  rallies.forEach(r => {
    const chip = r.chip;
    const wonByA = r.winner === "A";

    // Chip-Attribution: immer Spieler A
    if (chip === "AS+") { servePlus++; }
    else if (chip === "AS-") { serveMinus++; }
    else if (chip === "AN+") { receivePlus++; }
    else if (chip === "AN-") { receiveMinus++; }
    else if (chip === "R+") { rallyPlus++; }
    else if (chip === "R-") { rallyMinus++; }

    // Druckpunkte: wenn beide ≥8 Punkte → zählt für A
    if (score[0] >= 8 && score[1] >= 8) {
      pressureTotal++;
      if (wonByA) pressureWon++;
    }

    // Verlust-Serie für A
    if (!wonByA) {
      lossStreak++;
      if (lossStreak > maxLossStreak) {
        maxLossStreak = lossStreak;
        lossAt = score[0] + ":" + score[1];
      }
    } else {
      lossStreak = 0;
    }

    if (wonByA) score[0]++; else score[1]++;
  });

  const serveEff = (servePlus + serveMinus) > 0 ? servePlus / (servePlus + serveMinus) : NaN;
  const receiveStab = (receivePlus + receiveMinus) > 0 ? 1 - receiveMinus / (receivePlus + receiveMinus) : NaN;
  const rallyQual = (rallyPlus + rallyMinus) > 0 ? rallyPlus / (rallyPlus + rallyMinus) : NaN;
  const pressurePerf = pressureTotal > 0 ? pressureWon / pressureTotal : NaN;

  return {
    serveEff, servePlus, serveMinus,
    receiveStab, receivePlus, receiveMinus,
    rallyQual, rallyPlus, rallyMinus,
    pressurePerf, pressureWon, pressureTotal,
    longestLossSeries: maxLossStreak,
    longestLossAt: lossAt,
    setScore: set.score.slice()
  };
}

/* ============ COACH-BOT: buildMatchKeyStats ============ */
function buildMatchKeyStats(match) {
  // Aggregiere über alle Sätze
  let sp = 0, sm = 0, rcp = 0, rcm = 0, rp = 0, rm = 0, pw = 0, pt = 0;
  match.sets.forEach(s => {
    const b = s.briefing || buildSetBriefing(s);
    if (!isNaN(b.serveEff)) { sp += b.servePlus; sm += b.serveMinus; }
    if (!isNaN(b.receiveStab)) { rcp += b.receivePlus; rcm += b.receiveMinus; }
    if (!isNaN(b.rallyQual)) { rp += b.rallyPlus; rm += b.rallyMinus; }
    pw += b.pressureWon; pt += b.pressureTotal;
  });
  return {
    serveEff: (sp + sm) > 0 ? sp / (sp + sm) : NaN,
    receiveStab: (rcp + rcm) > 0 ? 1 - rcm / (rcp + rcm) : NaN,
    rallyQual: (rp + rm) > 0 ? rp / (rp + rm) : NaN,
    pressurePerf: pt > 0 ? pw / pt : NaN
  };
}

/* ============ COACH-BOT: STAT_TO_EXERCISES ============ */
const STAT_TO_EXERCISES = {
  serveEff_low:    ["T5", "T9", "T10", "T25", "T26"],
  receiveStab_low: ["T11", "T15", "T16", "T21", "T28"],
  rallyQual_low:   ["T7", "T8", "T23", "T6", "T1"],
  pressurePerf_low:["T36", "T35", "T14", "T13"]
};

function deriveTrainingFocus(keyStats) {
  // Finde 1-2 schwächste Kennzahlen
  const stats = [
    { key: "serveEff_low", val: isNaN(keyStats.serveEff) ? 1 : keyStats.serveEff },
    { key: "receiveStab_low", val: isNaN(keyStats.receiveStab) ? 1 : keyStats.receiveStab },
    { key: "rallyQual_low", val: isNaN(keyStats.rallyQual) ? 1 : keyStats.rallyQual },
    { key: "pressurePerf_low", val: isNaN(keyStats.pressurePerf) ? 1 : keyStats.pressurePerf }
  ].filter(s => !isNaN(s.val));
  stats.sort((a, b) => a.val - b.val);
  const focus = [];
  stats.slice(0, 2).forEach(s => {
    if (s.val < 0.65) { // nur wenn wirklich schwach
      const exIds = STAT_TO_EXERCISES[s.key] || [];
      focus.push(...exIds.slice(0, 2));
    }
  });
  return [...new Set(focus)].slice(0, 4);
}

/* ============ COACH-BOT: buildMatchReport ============ */
function buildMatchReport(match, view) {
  const ks = buildMatchKeyStats(match);
  const setWinsA = match.sets.filter(s => s.score[0] > s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  const setWinsB = match.sets.filter(s => s.score[0] < s.score[1] && isSetOver(s.score[0], s.score[1])).length;

  function pct(v) { return isNaN(v) ? "–" : Math.round(v * 100) + "%" ; }
  function statColor(v, good, ok) {
    if (isNaN(v)) return "var(--mut)";
    return v >= good ? "var(--kraft)" : v >= ok ? "var(--warm)" : "var(--red)";
  }

  if (view === "player") {
    // Stärkste Kennzahl
    const named = [
      { label: "Aufschlag-Effizienz", val: ks.serveEff },
      { label: "Annahme-Stabilität", val: ks.receiveStab },
      { label: "Rallye-Qualität", val: ks.rallyQual },
      { label: "Druckpunkte", val: ks.pressurePerf }
    ].filter(n => !isNaN(n.val));
    named.sort((a, b) => b.val - a.val);
    const best = named[0];

    const training = deriveTrainingFocus(ks);

    let html = `<div class="player-report-card"><h3>Spielergebnis</h3>`;
    html += `<div style="font-size:15px;font-weight:700;margin-bottom:8px">${esc(match.playerA.name)} <b style="font-size:24px;font-family:var(--disp)">${setWinsA}:${setWinsB}</b> ${esc(match.playerB.name)}</div>`;
    // Satzverläufe
    match.sets.forEach((s, i) => {
      if (!isSetOver(s.score[0], s.score[1])) return;
      html += `<span style="font-size:13px;color:var(--sub2);margin-right:10px">Satz ${i + 1}: ${s.score[0]}:${s.score[1]}</span>`;
    });
    html += `</div>`;

    if (best) {
      html += `<div class="highlight-stat">
        <div class="hs-val">${pct(best.val)} ✓</div>
        <div class="hs-lbl">Deine ${esc(best.label)} heute</div>
      </div>`;
    }

    // Entwicklungsaufgabe
    if (training.length) {
      const ex = byId(training[0]);
      html += `<div class="player-report-card"><h3>Deine Entwicklungsaufgabe</h3>`;
      html += `<div style="font-size:14px;font-weight:500;color:var(--ink)">`;
      if (ex) {
        html += `Arbeite weiter an: <b>${esc(ex.title)}</b> — ${esc(ex.goal || "")}`;
      } else {
        html += `Fokus auf Konstanz im nächsten Training.`;
      }
      html += `</div></div>`;
    }

    return html;

  } else {
    // Trainer-Ansicht
    let html = `<div class="player-report-card"><h3>Alle Kennzahlen im Überblick</h3>`;
    html += `<table class="set-table"><thead><tr>
      <th>Satz</th><th>Ergebnis</th><th>AS-Eff</th><th>AN-Stab</th><th>Rallye</th><th>Druck</th>
    </tr></thead><tbody>`;

    match.sets.forEach((s, i) => {
      if (!isSetOver(s.score[0], s.score[1])) return;
      const b = s.briefing || buildSetBriefing(s);
      html += `<tr>
        <td>Satz ${i + 1}</td>
        <td><b>${s.score[0]}:${s.score[1]}</b></td>
        <td class="${!isNaN(b.serveEff) && b.serveEff >= 0.65 ? 'good' : 'warn'}">${pct(b.serveEff)}</td>
        <td class="${!isNaN(b.receiveStab) && b.receiveStab >= 0.65 ? 'good' : 'warn'}">${pct(b.receiveStab)}</td>
        <td class="${!isNaN(b.rallyQual) && b.rallyQual >= 0.6 ? 'good' : 'warn'}">${pct(b.rallyQual)}</td>
        <td class="${!isNaN(b.pressurePerf) && b.pressurePerf >= 0.55 ? 'good' : 'warn'}">${pct(b.pressurePerf)}</td>
      </tr>`;
    });

    html += `<tr style="font-weight:700;border-top:2px solid var(--sep)">
      <td>Gesamt</td>
      <td>${setWinsA}:${setWinsB}</td>
      <td style="color:${statColor(ks.serveEff,.65,.45)}">${pct(ks.serveEff)}</td>
      <td style="color:${statColor(ks.receiveStab,.65,.45)}">${pct(ks.receiveStab)}</td>
      <td style="color:${statColor(ks.rallyQual,.6,.4)}">${pct(ks.rallyQual)}</td>
      <td style="color:${statColor(ks.pressurePerf,.55,.35)}">${pct(ks.pressurePerf)}</td>
    </tr></tbody></table></div>`;

    // Verlaufskurve
    html += `<div class="player-report-card"><h3>Punkteverlauf pro Satz</h3>`;
    match.sets.forEach((s, i) => {
      if (!isSetOver(s.score[0], s.score[1])) return;
      html += `<div style="margin-bottom:10px"><div style="font-size:11px;font-weight:700;color:var(--mut);margin-bottom:4px">SATZ ${i + 1}</div>`;
      html += buildRallyCurve(s);
      html += `</div>`;
    });
    html += `</div>`;

    // Satzpausen-Notizen
    const notes = match.sets.filter(s => s.coachNote);
    if (notes.length) {
      html += `<div class="player-report-card"><h3>Satzpausen-Notizen</h3>`;
      notes.forEach((s, i) => {
        html += `<div class="set-note-block"><b>Satz ${match.sets.indexOf(s) + 1}:</b> ${esc(s.coachNote)}</div>`;
      });
      html += `</div>`;
    }

    // Trainingsableitung
    const focus = deriveTrainingFocus(ks);
    if (focus.length) {
      html += `<div class="player-report-card"><h3>Trainingsableitung</h3>`;
      const statLabels = {
        serveEff_low: "Aufschlag-Effizienz",
        receiveStab_low: "Annahme-Stabilität",
        rallyQual_low: "Rallye-Qualität",
        pressurePerf_low: "Druckpunkte"
      };
      const weakStats = [
        { key: "serveEff_low", val: ks.serveEff },
        { key: "receiveStab_low", val: ks.receiveStab },
        { key: "rallyQual_low", val: ks.rallyQual },
        { key: "pressurePerf_low", val: ks.pressurePerf }
      ].filter(s => !isNaN(s.val) && s.val < 0.65).sort((a, b) => a.val - b.val).slice(0, 2);

      weakStats.forEach(ws => {
        html += `<div style="margin-bottom:10px"><div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--mut);margin-bottom:5px">
          Schwach: ${statLabels[ws.key]} (${pct(ws.val)})
        </div><div class="training-derive-card"><div class="tdc-lbl">Empfohlene Übungen</div>`;
        (STAT_TO_EXERCISES[ws.key] || []).slice(0, 3).forEach(id => {
          const ex = byId(id);
          if (!ex) return;
          html += `<button class="training-derive-pill" data-jump-exercise="${esc(id)}" title="${esc(ex.goal || '')}">${esc(id)} ${esc(ex.title)}</button>`;
        });
        html += `</div></div>`;
      });
      html += `</div>`;
    }

    return html;
  }
}

function buildRallyCurve(set) {
  // Mini-SVG: Punktedifferenz-Verlauf (A minus B)
  const W = 280, H = 48;
  const rallies = set.rallies;
  if (!rallies.length) return `<div style="font-size:12px;color:var(--mut)">Keine Rallye-Daten</div>`;
  const diffs = [];
  let a = 0, b = 0;
  rallies.forEach(r => {
    if (r.winner === "A") a++; else b++;
    diffs.push(a - b);
  });
  const min = Math.min(...diffs, -1), max = Math.max(...diffs, 1);
  const range = max - min || 2;
  const pts = diffs.map((d, i) => {
    const x = 10 + (i / Math.max(diffs.length - 1, 1)) * (W - 20);
    const y = H - 6 - ((d - min) / range) * (H - 12);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  });
  const zeroY = (H - 6 - ((0 - min) / range) * (H - 12)).toFixed(1);
  return `<div class="rally-curve"><svg viewBox="0 0 ${W} ${H}" style="width:100%;height:${H}px">
    <line x1="0" y1="${zeroY}" x2="${W}" y2="${zeroY}" stroke="var(--sep)" stroke-width="1" stroke-dasharray="3 2"/>
    <polyline points="${pts.join(" ")}" fill="none" stroke="var(--acc)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="2" y="10" font-size="7" fill="var(--mut)" font-family="-apple-system,sans-serif">${esc(set.score[0])}:${esc(set.score[1])} · ${rallies.length} Punkte</text>
  </svg></div>`;
}

/* ============ REPORT TABS ============ */
function renderMatchReport(view) {
  document.querySelectorAll(".match-report-tab").forEach(t => {
    t.classList.toggle("active", t.dataset.report === view);
  });
  const el = document.getElementById("matchReportContent"); if (!el || !activeMatch) return;
  el.innerHTML = buildMatchReport(activeMatch, view);
}

document.querySelectorAll(".match-report-tab").forEach(t => {
  t.addEventListener("click", () => renderMatchReport(t.dataset.report));
});

/* Jump to exercise in Planen-Tab */
document.addEventListener("click", e => {
  const t = e.target.closest("[data-jump-exercise]");
  if (!t) return;
  const id = t.dataset.jumpExercise;
  const ex = byId(id); if (!ex) return;
  addExercise(id);
  switchTab("planen");
  toast(`"${ex.title}" zum Plan hinzugefügt`);
});

/* ============ NEUES MATCH ============ */
document.getElementById("matchNewBtn").onclick = function () {
  activeMatch = null;
  _pendingChip = null;
  document.getElementById("matchSetup").style.display = "";
  document.getElementById("matchLive").style.display = "none";
  document.getElementById("matchFinish").style.display = "none";
  renderMatchPlayerDropdown();
};

/* ============ MATCH EXPORT — Druckansicht (V0.10.3.1) ============ */
document.getElementById("matchExportBtn").onclick = function () {
  if (!activeMatch) return;
  const playerReport = buildMatchReport(activeMatch, "player");
  const coachReport = buildMatchReport(activeMatch, "coach");
  const da = activeMatch.date;
  const setWinsA = activeMatch.sets.filter(s => s.score[0] > s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  const setWinsB = activeMatch.sets.filter(s => s.score[0] < s.score[1] && isSetOver(s.score[0], s.score[1])).length;

  const win = window.open("", "_blank", "width=900,height=700");
  if (!win) { toast("Popup blockiert – bitte Popup-Blocker deaktivieren"); return; }
  win.document.write(`<!DOCTYPE html>
<html lang="de"><head><meta charset="UTF-8">
<title>Match: ${esc(activeMatch.playerA.name)} vs ${esc(activeMatch.playerB.name)} – ${fmtDate(da)}</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',Arial,sans-serif;
    background:#fff;color:#000;font-size:12px;padding:20px}
  h1{font-size:20px;font-weight:800;margin-bottom:3px}
  .meta{color:#555;font-size:10.5px;margin-bottom:18px;padding-bottom:10px;border-bottom:2px solid #000}
  h2{font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;
    margin:22px 0 10px;padding-bottom:5px;border-bottom:1.5px solid #000}
  h3{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#666;margin:14px 0 7px}
  .player-report-card{border:1px solid #ddd;border-radius:5px;padding:12px 14px;margin-bottom:10px;page-break-inside:avoid}
  .highlight-stat{background:#f5f0ff;border:1px solid #c4b5fd;border-radius:5px;padding:10px 12px;margin-bottom:10px}
  .hs-val{font-size:26px;font-weight:800;color:#5b21b6}
  .hs-lbl{font-size:11px;color:#5b21b6;margin-top:2px}
  .set-table{width:100%;border-collapse:collapse;font-size:11px;margin-bottom:8px}
  .set-table th{text-align:left;font-size:9px;font-weight:700;text-transform:uppercase;
    padding:4px 6px;border-bottom:1.5px solid #000;letter-spacing:.07em;color:#333}
  .set-table td{padding:5px 6px;border-bottom:1px solid #eee}
  .set-table tr:last-child td{border-bottom:2px solid #000;font-weight:700}
  .good{color:#059669;font-weight:700}
  .warn{color:#dc2626;font-weight:700}
  .set-note-block{font-size:11px;color:#555;font-style:italic;padding:4px 8px;
    border-left:3px solid #c4b5fd;margin:4px 0 8px}
  .training-derive-card{background:#d1fae5;border:1px solid #6ee7b7;border-radius:5px;
    padding:9px 11px;margin:6px 0}
  .tdc-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;
    color:#065f46;margin-bottom:4px}
  .training-derive-pill{display:inline-block;background:#10b981;color:#fff;border-radius:100px;
    padding:3px 9px;font-size:11px;font-weight:700;margin:2px 3px 2px 0}
  .stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
  .stat-cell{background:#f5f5f5;border-radius:4px;padding:9px 11px}
  .sc-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#888;margin-bottom:2px}
  .sc-val{font-size:20px;font-weight:800}
  .sc-sub{font-size:9.5px;color:#666;margin-top:1px}
  .rally-curve svg{width:100%;max-width:380px;display:block}
  .page-break{page-break-before:always}
  .score-hero{font-size:36px;font-weight:800;letter-spacing:-.04em;margin:6px 0}
  .score-hero .sep{color:#999;font-weight:300;margin:0 4px}
  .score-hero .winner{color:#5b21b6}
  @media print{
    body{padding:10px}
    .player-report-card,.stat-cell,.highlight-stat{page-break-inside:avoid;
      -webkit-print-color-adjust:exact;print-color-adjust:exact}
    .good,.warn,.hs-val,.score-hero .winner{-webkit-print-color-adjust:exact;print-color-adjust:exact}
    .training-derive-card,.training-derive-pill{-webkit-print-color-adjust:exact;print-color-adjust:exact}
    .no-print{display:none}
  }
</style></head><body>

<div class="no-print" style="background:#f0f0f0;padding:12px 16px;margin:-20px -20px 20px;
  display:flex;align-items:center;gap:12px;font-size:13px">
  <b>TT-Baukasten Match-Bericht</b>
  <button onclick="window.print()" style="padding:8px 18px;background:#5b21b6;color:#fff;
    border:none;border-radius:100px;font-size:13px;font-weight:700;cursor:pointer">
    🖨 Drucken / Als PDF speichern
  </button>
  <span style="color:#555;font-size:12px">Tipp: Im Druck-Dialog "Als PDF speichern" wählen</span>
</div>

<h1>Match-Bericht</h1>
<div class="meta">
  <b>${esc(activeMatch.playerA.name)}</b> vs ${esc(activeMatch.playerB.name)}
  ${activeMatch.tournament ? " · " + esc(activeMatch.tournament) : ""}
   · ${fmtDate(da)}
   · TT-Baukasten V0.10.3.1 © Justin Jungk
</div>

<!-- ═══ SEITE 1: SPIELER-ANSICHT ═══ -->
<h2>Spieler-Ansicht</h2>
<div class="score-hero">
  <span class="${setWinsA > setWinsB ? 'winner' : ''}">${setWinsA}</span><span class="sep">:</span><span class="${setWinsB > setWinsA ? 'winner' : ''}">${setWinsB}</span>
  <span style="font-size:14px;font-weight:400;color:#555;margin-left:10px">${esc(activeMatch.playerA.name)} vs ${esc(activeMatch.playerB.name)}</span>
</div>
${playerReport}

<!-- ═══ SEITE 2: TRAINER-ANSICHT ═══ -->
<div class="page-break"></div>
<h2>Trainer-Ansicht (vollständig)</h2>
${coachReport}

</body></html>`);
  win.document.close();
  win.onload = () => { /* Druck-Button im Fenster, kein auto-print */ };
  toast("Bericht geöffnet — Drucken oder als PDF speichern");
};

/* ============ MATCH-BERICHT MODAL (aus Statistik-Liste) ============ */
let _modalMatch = null;

function openMatchReportModal(match) {
  _modalMatch = match;
  const sA = match.sets.filter(s => s.score[0] > s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  const sB = match.sets.filter(s => s.score[0] < s.score[1] && isSetOver(s.score[0], s.score[1])).length;
  document.getElementById("matchReportModalTitle").textContent =
    `${match.playerA.name} ${sA}:${sB} ${match.playerB.name} · ${fmtDate(match.date)}`;
  renderMatchReportModal("player");
  document.getElementById("matchReportModal").classList.add("open");
}

function renderMatchReportModal(view) {
  if (!_modalMatch) return;
  document.querySelectorAll("[data-mreport]").forEach(t => {
    t.classList.toggle("active", t.dataset.mreport === view);
  });
  document.getElementById("matchReportModalBody").innerHTML = buildMatchReport(_modalMatch, view);
}

document.querySelectorAll("[data-mreport]").forEach(t => {
  t.addEventListener("click", () => renderMatchReportModal(t.dataset.mreport));
});
document.getElementById("matchReportModalClose").onclick = () => {
  document.getElementById("matchReportModal").classList.remove("open");
  _modalMatch = null;
};
document.getElementById("matchReportModal").addEventListener("click", e => {
  if (e.target === document.getElementById("matchReportModal")) {
    document.getElementById("matchReportModal").classList.remove("open");
    _modalMatch = null;
  }
});

// Click on match list item in stats
document.addEventListener("click", e => {
  const t = e.target.closest("[data-open-match]");
  if (!t) return;
  const idx = parseInt(t.dataset.openMatch);
  const sorted = [...matches].sort((a, b) => b.date.localeCompare(a.date));
  if (sorted[idx]) openMatchReportModal(sorted[idx]);
});

/* ============ MATCH-TAB INIT ============ */
function initMatchTab() {
  renderMatchPlayerDropdown();
  if (!activeMatch) {
    document.getElementById("matchSetup").style.display = "";
    document.getElementById("matchLive").style.display = "none";
    document.getElementById("matchFinish").style.display = "none";
  }
}

/* ============ WINDOW.__TTK ERWEITERUNG ============ */
Object.assign(window.__TTK, {
  players, matches,
  get activeMatch() { return activeMatch; },
  buildSetBriefing, buildMatchReport, buildMatchKeyStats, deriveTrainingFocus, STAT_TO_EXERCISES
});



/* ================================================================
   TT-BAUKASTEN V0.11.0 — SUPABASE BACKEND
   ================================================================
   KONFIGURATION: Trage hier deine Supabase-Credentials ein.
   Zu finden unter: Supabase Dashboard → Project Settings → API
   ================================================================ */

const SUPABASE_URL  = 'https://gxnsjaxxnvkephzvjdek.supabase.co';   // z.B. https://xyzxyz.supabase.co
const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd4bnNqYXh4bnZrZXBoenZqZGVrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODExOTA3NDMsImV4cCI6MjA5Njc2Njc0M30.h350hqxeae099o9zsXZATVKlhE9wKNoJ2g4E2-TK9h8'; // beginnt mit "eyJ..."

/* ── Supabase-Client (lädt SDK lazy via CDN) ── */
let _sb = null;  // Supabase client instance
let _sbUser = null;
let _sbReady = false;

async function initSupabase() {
  if (_sb) return _sb;
  // Credentials noch nicht eingetragen → offline bleiben
  if (SUPABASE_URL.startsWith('DEINE') || SUPABASE_ANON.startsWith('DEIN')) {
    setSyncState('offline', 'nicht konfiguriert');
    return null;
  }
  try {
    // Supabase JS SDK v2 via CDN
    if (!window.supabase) {
      await new Promise((res, rej) => {
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js';
        s.onload = res; s.onerror = rej;
        document.head.appendChild(s);
      });
    }
    _sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON, {
      auth: {
        detectSessionInUrl: true,
        flowType: 'pkce',
        persistSession: true,
        autoRefreshToken: true,
      }
    });

    // Handle magic link redirect — token arrives in URL hash or query params
    const urlParams = new URLSearchParams(window.location.search);
    const hashParams = new URLSearchParams(window.location.hash.replace('#', ''));
    if (urlParams.get('code') || hashParams.get('access_token')) {
      // Let Supabase handle the token exchange automatically
      // onAuthStateChange will fire with SIGNED_IN event
      console.log('Auth redirect detected, processing…');
    }
    // Auth state listener
    _sb.auth.onAuthStateChange(async (event, session) => {
      _sbUser = session?.user ?? null;
      if (window._removeLoadingOverlay) window._removeLoadingOverlay();
      if (_sbUser) {
        document.getElementById('authScreen').classList.remove('visible'); document.getElementById('authScreen').style.display='none';
        setSyncState('syncing', 'lade Daten…');
        await loadAllFromSupabase();
        setSyncState('synced', _sbUser.email?.split('@')[0] || 'angemeldet');
        checkMigration();
      } else {
        setSyncState('offline', 'nicht angemeldet');
        document.getElementById('authScreen').style.display='flex'; document.getElementById('authScreen').classList.add('visible');
      }
    });
    // Check existing session
    const { data: { session } } = await _sb.auth.getSession();
    if (session) {
      _sbUser = session.user;
      document.getElementById('authScreen').classList.remove('visible'); document.getElementById('authScreen').style.display='none';
    } else {
      if (window._removeLoadingOverlay) window._removeLoadingOverlay();
      document.getElementById('authScreen').style.display='flex'; document.getElementById('authScreen').classList.add('visible');
    }
    _sbReady = true;
    return _sb;
  } catch(e) {
    console.error('Supabase init error:', e);
    setSyncState('error', 'Verbindungsfehler');
    return null;
  }
}

/* ── Sync-Status-Pill ── */
function setSyncState(state, label) {
  const pill = document.getElementById('syncPill');
  const lbl  = document.getElementById('syncLabel');
  if (!pill || !lbl) return;
  pill.className = 'sync-pill ' + state;
  lbl.textContent = label;
}

/* ── Auth UI ── */
document.getElementById('authSubmit').addEventListener('click', async () => {
  const email = document.getElementById('authEmail').value.trim();
  const statusEl = document.getElementById('authStatus');
  const btn = document.getElementById('authSubmit');
  if (!email || !email.includes('@')) {
    statusEl.textContent = 'Bitte eine gültige E-Mail-Adresse eingeben.';
    statusEl.className = 'auth-status err';
    return;
  }
  btn.disabled = true;
  btn.textContent = 'Sende Link…';
  statusEl.textContent = '';
  statusEl.className = 'auth-status';
  try {
    const sb = await initSupabase();
    if (!sb) { statusEl.textContent = 'Supabase nicht konfiguriert.'; statusEl.className = 'auth-status err'; btn.disabled = false; btn.textContent = 'Magic Link senden'; return; }
    const { error } = await sb.auth.signInWithOtp({
      email,
      options: {
        shouldCreateUser: true,
        emailRedirectTo: window.location.href.split('?')[0].split('#')[0],
      }
    });
    if (error) throw error;
    statusEl.textContent = '✓ Link gesendet! Bitte E-Mail prüfen und auf den Link klicken.';
    statusEl.className = 'auth-status ok';
    btn.textContent = 'Link erneut senden';
  } catch(e) {
    statusEl.textContent = 'Fehler: ' + (e.message || 'Unbekannter Fehler');
    statusEl.className = 'auth-status err';
  } finally {
    btn.disabled = false;
  }
});

// Sync pill click → Abmelden
document.getElementById('syncPill').addEventListener('click', async () => {
  if (!_sbUser) return;
  if (!confirm('Abmelden? Deine Daten bleiben in Supabase gespeichert.')) return;
  await _sb.auth.signOut();
  _sbUser = null;
  setSyncState('offline', 'nicht angemeldet');
});

/* ── Daten von Supabase laden ── */
async function loadAllFromSupabase() {
  if (!_sb || !_sbUser) return;
  const uid = _sbUser.id;
  try {
    // Settings
    const { data: sData } = await _sb.from('settings').select('data').eq('user_id', uid).maybeSingle();
    if (sData?.data) {
      SETTINGS = Object.assign({ club: 'TV Bonn-Geislar', budgets: { ...DEFAULT_BUDGETS }, weights: { ...DEFAULT_WEIGHTS } }, sData.data);
      const clubEl = document.getElementById('brandClub');
      if (clubEl) clubEl.textContent = SETTINGS.club;
    }

    // Draft
    const { data: dData } = await _sb.from('draft').select('data').eq('user_id', uid).maybeSingle();
    if (dData?.data) { state = dData.data; }

    // Training history
    const { data: hData } = await _sb.from('training_sessions').select('*').eq('user_id', uid).order('date', { ascending: false });
    if (hData) {
      trainLog = hData.map(r => ({ date: r.date, sel: r.sel, note: r.note || '', exNotes: r.ex_notes || '', count: r.count, savedAt: r.saved_at }));
      invalidateHistCache();
    }

    // Custom exercises
    const { data: cData } = await _sb.from('custom_exercises').select('data').eq('user_id', uid);
    if (cData) { custom = cData.map(r => r.data); }

    // Players
    const { data: pData } = await _sb.from('players').select('*').eq('user_id', uid);
    if (pData) {
      players = pData.map(r => ({ id: r.player_id, name: r.name, hand: r.hand, birthyear: r.birthyear, style: r.style, matchHistory: r.match_history || [] }));
    }

    // Matches
    const { data: mData } = await _sb.from('matches').select('*').eq('user_id', uid).order('date', { ascending: false });
    if (mData) {
      matches = mData.map(r => ({ id: r.match_id, date: r.date, tournament: r.tournament, playerA: r.player_a, playerB: r.player_b, format: r.format, sets: r.sets, result: r.result, firstServerSet1: r.first_server_set1 }));
    }

    render();
  } catch(e) {
    console.error('loadAllFromSupabase error:', e);
    setSyncState('error', 'Ladefehler');
  }
}

/* ── Schreib-Operationen mit Supabase-Fallback ── */

// Override saveDraft
const _origSaveDraft = saveDraft;
window.saveDraft = async function() {
  _origSaveDraft();  // localStorage immer schreiben (Offline-Fallback)
  if (!_sb || !_sbUser) return;
  try {
    await _sb.from('draft').upsert({ user_id: _sbUser.id, data: state, updated_at: new Date().toISOString() }, { onConflict: 'user_id' });
  } catch(e) { console.warn('draft sync error:', e); }
};
saveDraft = window.saveDraft;

// Override saveSettings
const _origSaveSettings = saveSettings;
window.saveSettings = async function() {
  _origSaveSettings();
  if (!_sb || !_sbUser) return;
  try {
    await _sb.from('settings').upsert({ user_id: _sbUser.id, data: SETTINGS, updated_at: new Date().toISOString() }, { onConflict: 'user_id' });
  } catch(e) { console.warn('settings sync error:', e); }
};
saveSettings = window.saveSettings;

// Override setHistory (training sessions)
const _origSetHistory = setHistory;
window.setHistory = async function(log) {
  _origSetHistory(log);
  if (!_sb || !_sbUser) return;
  // Sync the most recently added/modified entry only
  if (!log.length) return;
  const entry = log[0]; // sorted desc, most recent first
  try {
    await _sb.from('training_sessions').upsert({
      user_id: _sbUser.id,
      date: entry.date,
      sel: entry.sel,
      note: entry.note || '',
      ex_notes: entry.exNotes || '',
      count: entry.count || null,
      saved_at: entry.savedAt || Date.now()
    }, { onConflict: 'user_id,date' });
    setSyncState('synced', _sbUser.email?.split('@')[0] || 'synced');
  } catch(e) { console.warn('history sync error:', e); setSyncState('error', 'Sync-Fehler'); }
};
setHistory = window.setHistory;

// Override savePlayers
const _origSavePlayers = savePlayers;
window.savePlayers = async function() {
  _origSavePlayers();
  if (!_sb || !_sbUser) return;
  try {
    await Promise.all(players.map(p =>
      _sb.from('players').upsert({
        user_id: _sbUser.id, player_id: p.id, name: p.name,
        hand: p.hand, birthyear: p.birthyear, style: p.style,
        match_history: p.matchHistory || []
      }, { onConflict: 'user_id,player_id' })
    ));
  } catch(e) { console.warn('players sync error:', e); }
};
savePlayers = window.savePlayers;

// Override saveMatches
const _origSaveMatches = saveMatches;
window.saveMatches = async function() {
  _origSaveMatches();
  if (!_sb || !_sbUser) return;
  if (!matches.length) return;
  const m = matches[matches.length - 1]; // last added
  try {
    await _sb.from('matches').upsert({
      user_id: _sbUser.id, match_id: m.id, date: m.date,
      tournament: m.tournament || '', player_a: m.playerA, player_b: m.playerB,
      format: m.format, sets: m.sets, result: m.result || '',
      first_server_set1: m.firstServerSet1 || 'A'
    }, { onConflict: 'user_id,match_id' });
  } catch(e) { console.warn('matches sync error:', e); }
};
saveMatches = window.saveMatches;

/* ── Migration: localStorage → Supabase ── */
function checkMigration() {
  // Prüfe ob localStorage noch unveröffentlichte Daten hat
  const hasHistory = (lsGet('ttk_history', [])).length > 0;
  const hasCustom  = (lsGet('ttk_custom',  [])).length > 0;
  const migDone    = lsGet('ttk_migrated_v11', false);
  if ((hasHistory || hasCustom) && !migDone) {
    showMigrationBanner();
  }
}

function showMigrationBanner() {
  // Zeige Banner im Planen-Tab header
  const hero = document.getElementById('hero');
  if (!hero || document.getElementById('migrateBanner')) return;
  const banner = document.createElement('div');
  banner.id = 'migrateBanner';
  banner.className = 'migrate-banner';
  banner.innerHTML = `<div class="mb-text"><b>Lokale Daten gefunden</b><br>Deine bisherigen Trainingsdaten aus dem Browser möchtest du in die Cloud übertragen?</div>
    <button id="migrateTrigger">Jetzt übertragen</button>`;
  hero.insertAdjacentElement('afterend', banner);
  document.getElementById('migrateTrigger').onclick = runMigration;
}

async function runMigration() {
  if (!_sb || !_sbUser) return;
  const btn = document.getElementById('migrateTrigger');
  if (btn) { btn.disabled = true; btn.textContent = 'Überträgt…'; }
  setSyncState('syncing', 'migriere…');

  try {
    const uid = _sbUser.id;

    // Settings
    const localSettings = lsGet('ttk_settings', null);
    if (localSettings) {
      await _sb.from('settings').upsert({ user_id: uid, data: localSettings }, { onConflict: 'user_id' });
    }

    // Draft
    const localDraft = lsGet('ttk_draft', null);
    if (localDraft) {
      await _sb.from('draft').upsert({ user_id: uid, data: localDraft }, { onConflict: 'user_id' });
    }

    // Training history
    const localHistory = lsGet('ttk_history', []);
    for (const entry of localHistory) {
      await _sb.from('training_sessions').upsert({
        user_id: uid, date: entry.date, sel: entry.sel,
        note: entry.note || '', ex_notes: entry.exNotes || '',
        count: entry.count || null, saved_at: entry.savedAt || Date.now()
      }, { onConflict: 'user_id,date' });
    }

    // Custom exercises
    const localCustom = lsGet('ttk_custom', []);
    for (const ex of localCustom) {
      await _sb.from('custom_exercises').upsert({ user_id: uid, exercise_id: ex.id, data: ex }, { onConflict: 'user_id,exercise_id' });
    }

    // Players
    const localPlayers = lsGet('ttk_players', []);
    for (const p of localPlayers) {
      await _sb.from('players').upsert({
        user_id: uid, player_id: p.id, name: p.name,
        hand: p.hand, birthyear: p.birthyear, style: p.style,
        match_history: p.matchHistory || []
      }, { onConflict: 'user_id,player_id' });
    }

    // Matches
    const localMatches = lsGet('ttk_matches', []);
    for (const m of localMatches) {
      await _sb.from('matches').upsert({
        user_id: uid, match_id: m.id, date: m.date,
        tournament: m.tournament || '', player_a: m.playerA, player_b: m.playerB,
        format: m.format, sets: m.sets, result: m.result || '',
        first_server_set1: m.firstServerSet1 || 'A'
      }, { onConflict: 'user_id,match_id' });
    }

    // Mark as done
    lsSet('ttk_migrated_v11', true);
    const banner = document.getElementById('migrateBanner');
    if (banner) banner.remove();
    setSyncState('synced', _sbUser.email?.split('@')[0] || 'synced');
    toast(`Migration abgeschlossen: ${localHistory.length} Trainings, ${localCustom.length} Übungen, ${localMatches.length} Matches übertragen`);
  } catch(e) {
    console.error('Migration error:', e);
    setSyncState('error', 'Migrationsfehler');
    toast('Fehler bei der Migration: ' + (e.message || 'unbekannt'));
    const btn = document.getElementById('migrateTrigger');
    if (btn) { btn.disabled = false; btn.textContent = 'Erneut versuchen'; }
  }
}

/* ── Init ── */
// Show loading state while checking auth
(function() {
  const authEl = document.getElementById('authScreen');
  if (!authEl) return;
  // Show a brief loading overlay
  const overlay = document.createElement('div');
  overlay.id = 'loadingOverlay';
  overlay.style.cssText = 'position:fixed;inset:0;z-index:199;background:var(--bg);display:flex;align-items:center;justify-content:center;';
  overlay.innerHTML = '<div style="font-family:var(--disp);font-size:18px;font-weight:600;color:var(--sub2);letter-spacing:-.02em">TT<span style="color:var(--acc)">.</span>Baukasten lädt…</div>';
  document.body.appendChild(overlay);
  
  // Remove overlay after auth check (max 3s fallback)
  const removeOverlay = () => { if(overlay.parentNode) overlay.remove(); };
  setTimeout(removeOverlay, 3000);
  window._removeLoadingOverlay = removeOverlay;
})();

initSupabase().then(() => {
  if (window._removeLoadingOverlay) window._removeLoadingOverlay();
});

})(); // Ende IIFE
</script>
</body>
</html>
