/* ============ TAKTIK-BOARD LOGIK (V0.10.2) ============ */
let _taktikMod=null,_taktikIdx=null,_taktikZones=[];

function openTaktikBoard(mod,idx){
  _taktikMod=mod;
  _taktikIdx=idx;
  _taktikZones=[...(state.sel[mod][idx].zones||[])];
  const ex=byId(state.sel[mod][idx].id);
  const title=ex?esc(ex.title):"Übung";
  document.getElementById("taktikModalTitle").textContent="Zielzonen · "+ex.title;
  renderTaktikBoard();
  document.getElementById("taktikModalBg").classList.add("open");
}

function renderTaktikBoard(){
  /* SVG-Zonen einfärben */
  Object.keys(TT_ZONES).forEach(zid=>{
    const el=document.getElementById("zone-"+zid);
    if(!el)return;
    el.className.baseVal="tt-zone"; // reset
    if(_taktikZones.includes(zid)){
      el.classList.add("active-"+zid);
    }
  });
  /* Chip-Zeile aktualisieren */
  const sel=document.getElementById("taktikSelected");
  const hint=document.getElementById("taktikNoneHint");
  if(!sel)return;
  if(!_taktikZones.length){
    hint.style.display="";
    // Remove any old chips (keep hint)
    [...sel.children].forEach(c=>{if(c!==hint)c.remove();});
    return;
  }
  hint.style.display="none";
  [...sel.children].forEach(c=>{if(c!==hint)c.remove();});
  _taktikZones.forEach(zid=>{
    if(!TT_ZONES[zid])return;
    const chip=document.createElement("span");
    chip.className="zone-chip "+zid;
    chip.textContent=TT_ZONES[zid].label;
    sel.appendChild(chip);
  });
}

function taktikToggleZone(zid){
  if(!TT_ZONES[zid])return;
  const i=_taktikZones.indexOf(zid);
  if(i>=0)_taktikZones.splice(i,1);
  else _taktikZones.push(zid);
  renderTaktikBoard();
}

function saveTaktikZones(){
  if(_taktikMod===null||_taktikIdx===null)return;
  state.sel[_taktikMod][_taktikIdx].zones=_taktikZones.length?[..._taktikZones]:undefined;
  _taktikMod=null;_taktikIdx=null;_taktikZones=[];
  document.getElementById("taktikModalBg").classList.remove("open");
  saveDraft();
  render();
}

/* Zone SVG click handler – delegated */
document.getElementById("taktikBoard").addEventListener("click",e=>{
  const z=e.target.closest(".tt-zone");
  if(z&&z.dataset.zone)taktikToggleZone(z.dataset.zone);
});
document.getElementById("taktikClose").onclick=()=>{
  document.getElementById("taktikModalBg").classList.remove("open");
};
document.getElementById("taktikSave").onclick=saveTaktikZones;
document.getElementById("taktikClear").onclick=()=>{
  _taktikZones=[];renderTaktikBoard();
};
document.getElementById("taktikModalBg").addEventListener("click",e=>{
  if(e.target===document.getElementById("taktikModalBg"))
    document.getElementById("taktikModalBg").classList.remove("open");
});


/* ================================================================
   TT-BAUKASTEN V0.9 — NEUE NAVIGATION & RENDER-FUNKTIONEN
   ================================================================ */

/* ---- Tab-Navigation ---- */
function switchTab(tabId){
  document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"));
  document.querySelectorAll(".bnav-item").forEach(b=>b.classList.remove("active"));
  const screen = document.getElementById("tab-"+tabId);
  if(screen) screen.classList.add("active");
  document.querySelectorAll(".bnav-item").forEach(b=>{
    if(b.dataset.tab===tabId) b.classList.add("active");
  });
  if(tabId==="auswerten") renderAuswerten();
  if(tabId==="geplant") renderGeplant();
  if(tabId==="einstellungen") initSettingsTab();
  if(tabId==="match") initMatchTab();
}

document.querySelectorAll(".bnav-item").forEach(btn=>{
  btn.addEventListener("click",()=>switchTab(btn.dataset.tab));
});

/* ---- Auswerten-Tab ---- */
function countMilestones(){
  const sorted=[...trainLog].sort((a,b)=>a.date.localeCompare(b.date));
  const found=new Set();
  sorted.forEach(h=>{
    const doneUpTo={};
    sorted.filter(x=>x.date<=h.date).forEach(x=>{
      const seen=new Set();
      for(const m in x.sel)(x.sel[m]||[]).forEach(it=>seen.add(it.id));
      seen.forEach(id=>{doneUpTo[id]=(doneUpTo[id]||0)+1;});
    });
    allEx().filter(e=>e.needs&&e.needs.length&&e.needs.every(n=>(doneUpTo[n]||0)>=2)).forEach(e=>{
      if(!found.has(e.id))found.add(e.id);
    });
  });
  return found.size;
}

/* ---- Auswerten Sub-Tab Navigation ---- */
let _activeStatsTab = "training";
document.querySelectorAll(".stats-subtab").forEach(btn => {
  btn.addEventListener("click", () => {
    _activeStatsTab = btn.dataset.stab;
    document.querySelectorAll(".stats-subtab").forEach(b => b.classList.toggle("active", b.dataset.stab === _activeStatsTab));
    document.getElementById("statsTraining").style.display = _activeStatsTab === "training" ? "" : "none";
    document.getElementById("statsMatches").style.display  = _activeStatsTab === "matches"  ? "" : "none";
    if (_activeStatsTab === "matches") renderMatchStats();
    else renderTrainingStats();
  });
});

function renderAuswerten(){
  const mE = document.getElementById("metricEinheiten");
  const mF = document.getElementById("metricFreigeschaltet");
  if(mE) mE.textContent = trainLog.length;
  if(mF) mF.textContent = countMilestones();
  if(_activeStatsTab === "training") renderTrainingStats();
  else renderMatchStats();
}

function renderTrainingStats() {
  const el = document.getElementById("statsContent"); if(!el) return;
  if(!trainLog.length){
    el.innerHTML=`<div class="stat-empty">Noch keine Daten — speichere zuerst ein paar Trainings.</div>`;
    const spBtn=document.querySelector("#seasonPrintBtn"); if(spBtn) spBtn.style.display="none";
    return;
  }
  const SEASON=8;
  const sorted=[...trainLog].sort((a,b)=>a.date.localeCompare(b.date));
  const curBlock=sorted.slice(-SEASON);
  const prevBlock=sorted.slice(-SEASON*2,-SEASON);

  function techCounts(entries){
    const c={};TT_TOPICS.forEach(t=>{c[t]=0;});
    entries.forEach(h=>{
      const seen=new Set();
      (h.sel.tt||[]).forEach(it=>{(byId(it.id)?.covers?.tech||[]).forEach(t=>{if(!seen.has(t)){seen.add(t);if(c[t]!==undefined)c[t]++;}});});
    });
    return c;
  }
  const curTech=techCounts(curBlock);
  const prevTech=prevBlock.length?techCounts(prevBlock):null;

  let html = "";

  // Themen-Ampel mit Delta
  html += `<div class="section-card"><h3>Themen-Bilanz — letzte ${curBlock.length} Einheiten</h3>`;
  TT_TOPICS.forEach(t=>{
    const cnt=curTech[t]||0;
    const target=DEFAULT_TOPIC_TARGETS[t]||3;
    const ratio=cnt/Math.max(target,1);
    const pct=Math.min(100,Math.round(ratio*100));
    const dotColor=ratio>=0.75?"var(--kraft)":ratio>=0.4?"var(--warm)":"var(--red)";
    const prev=prevTech?prevTech[t]:null;
    const delta=prev!==null?(cnt-prev):null;
    const deltaStr=delta!==null&&delta!==0
      ?` <span style="font-size:10px;font-weight:700;color:${delta>0?"var(--kraft)":"var(--red)"}">${delta>0?"+":""}${delta}</span>` :"";
    html+=`<div class="ampel-row">
      <span class="albl"><span class="ampel-dot" style="background:${dotColor}"></span>${esc(t)}${deltaStr}</span>
      <div class="abar-wrap"><div class="abar" style="width:${pct}%;background:${dotColor}"></div></div>
      <span class="aval" style="color:${dotColor}">${cnt}/${target}</span>
    </div>`;
  });
  html+=`<div class="ampel-legend">
    <span><span class="d" style="background:var(--kraft)"></span>≥75% Soll</span>
    <span><span class="d" style="background:var(--warm)"></span>40–74%</span>
    <span><span class="d" style="background:var(--red)"></span>&lt;40%</span>
    ${prevBlock.length?`<span style="color:var(--mut);font-size:11px">+/− vs. Vorperiode</span>`:""}
  </div></div>`;

  // Top-Übungen Frequenz
  const exFreq = {};
  trainLog.forEach(h => { for(const mod in h.sel)(h.sel[mod]||[]).forEach(it => { exFreq[it.id]=(exFreq[it.id]||0)+1; }); });
  const topEx = Object.entries(exFreq).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const maxFreq = topEx[0]?.[1]||1;
  if(topEx.length){
    html += `<div class="section-card"><h3>Meisttrainierte Übungen</h3><div class="freq-grid">`;
    topEx.forEach(([id,cnt]) => {
      const ex=byId(id); if(!ex) return;
      const last=lastDoneMap()[id];
      html += `<div class="freq-cell">
        <div class="fc-name" title="${esc(ex.title)}">${esc(ex.title)}</div>
        <div class="fc-count">${cnt}×</div>
        <div class="fc-bar" style="width:${Math.round(cnt/maxFreq*100)}%"></div>
        ${last?`<div class="fc-last">zuletzt ${fmtDate(last)}</div>`:""}
      </div>`;
    });
    html += `</div></div>`;
  }

  // Kraft-Abdeckung
  const muscFreq={};MUSCLES.forEach(m=>{muscFreq[m]=0;});
  trainLog.forEach(h=>{(h.sel.kraft||[]).forEach(it=>{(byId(it.id)?.covers?.musc||[]).forEach(m=>{if(muscFreq[m]!==undefined)muscFreq[m]++;});});});
  html += `<div class="section-card"><h3>Kraft — Muskelgruppen-Abdeckung</h3>`;
  MUSCLES.forEach(m=>{
    const cnt=muscFreq[m]||0;
    const pct=Math.min(100,Math.round(cnt/Math.max(trainLog.length,1)*100));
    const color=pct>=50?"var(--kraft)":pct>=25?"var(--warm)":"var(--red)";
    html+=`<div class="ampel-row">
      <span class="albl"><span class="ampel-dot" style="background:${color}"></span>${esc(m)}</span>
      <div class="abar-wrap"><div class="abar" style="width:${pct}%;background:${color}"></div></div>
      <span class="aval" style="color:${color}">${cnt}×</span>
    </div>`;
  });
  html+=`</div>`;

  // Meilensteine
  const milestones=[];
  sorted.forEach(h=>{
    const doneUpTo={};
    sorted.filter(x=>x.date<=h.date).forEach(x=>{const seen=new Set();for(const m in x.sel)(x.sel[m]||[]).forEach(it=>seen.add(it.id));seen.forEach(id=>{doneUpTo[id]=(doneUpTo[id]||0)+1;});});
    allEx().filter(e=>e.needs&&e.needs.length&&e.needs.every(n=>(doneUpTo[n]||0)>=2)).forEach(e=>{if(!milestones.find(ml=>ml.id===e.id))milestones.push({id:e.id,date:h.date,title:e.title,prog:e.prog});});
  });
  html+=`<div class="section-card"><h3>Freigeschaltete Übungen (${milestones.length})</h3>`;
  if(milestones.length){
    html+=milestones.slice(-8).reverse().map(ml=>`<div class="milestone-item"><span class="mi-date">${fmtDate(ml.date)}</span><span class="mi-name">${esc(ml.title)}</span><span class="mi-badge">${esc(ml.prog||"aufbauend")}</span></div>`).join("");
    if(milestones.length>8)html+=`<p style="font-size:11.5px;color:var(--mut);margin-top:6px">+${milestones.length-8} weitere</p>`;
  }else{ html+=`<div class="stat-empty">Noch keine Übungen freigeschaltet.</div>`; }
  html+=`</div>`;

  el.innerHTML=html;
  const spBtn=document.querySelector("#seasonPrintBtn"); if(spBtn) spBtn.style.display="";
}

function renderMatchStats() {
  const el = document.getElementById("matchStatsContent"); if(!el) return;
  if(!matches.length){
    el.innerHTML=`<div class="stat-empty">Noch keine Matches aufgezeichnet.<br><br>Starte ein Match im Match-Tab.</div>`;
    return;
  }
  function pct(v){ return isNaN(v)?"--":Math.round(v*100)+"%"; }
  function statCls(v,good,ok){ if(isNaN(v))return""; return v>=good?"good":v>=ok?"":"warn"; }

  let html="";

  // Sparkline-Trend
  const recent=[...matches].sort((a,b)=>a.date.localeCompare(b.date)).slice(-7);
  if(recent.length>=2){
    html+=`<div class="section-card"><h3>Kennzahlen-Trend — letzte ${recent.length} Matches</h3>`;
    const metrics=[
      {key:"serveEff",   label:"Aufschlag-Eff.",good:.65,ok:.45},
      {key:"receiveStab",label:"Annahme-Stab.", good:.65,ok:.45},
      {key:"rallyQual",  label:"Rallye-Qual.",  good:.60,ok:.40},
      {key:"pressurePerf",label:"Druckpunkte", good:.55,ok:.35},
    ];
    metrics.forEach(m=>{
      const vals=recent.map(match=>buildMatchKeyStats(match)[m.key]);
      if(vals.every(v=>isNaN(v)))return;
      const last=vals.filter(v=>!isNaN(v)).pop();
      const color=isNaN(last)?"var(--mut)":last>=m.good?"var(--kraft)":last>=m.ok?"var(--warm)":"var(--red)";
      html+=`<div class="sparkline-row">
        <span class="sr-lbl">${esc(m.label)}</span>
        ${buildSparklineSVG(vals,m.good,m.ok)}
        <span class="sr-val" style="color:${color}">${pct(last)}</span>
      </div>`;
    });
    html+=`</div>`;
  }

  // Win/Loss
  const wins=matches.filter(m=>m.result&&m.result.startsWith(m.playerA.name)).length;
  const losses=matches.length-wins;
  html+=`<div class="section-card"><h3>Bilanz</h3>
    <div style="display:flex;gap:14px;align-items:center;margin-bottom:6px">
      <div style="text-align:center"><div style="font-family:var(--disp);font-size:42px;font-weight:700;color:var(--kraft);line-height:1">${wins}</div><div style="font-size:11px;color:var(--mut)">Siege</div></div>
      <div style="font-size:28px;color:var(--mut);font-weight:300">:</div>
      <div style="text-align:center"><div style="font-family:var(--disp);font-size:42px;font-weight:700;color:var(--red);line-height:1">${losses}</div><div style="font-size:11px;color:var(--mut)">Niederlagen</div></div>
      <div style="flex:1;text-align:right"><div style="font-size:24px;font-weight:700;color:var(--ink)">${matches.length>0?Math.round(wins/matches.length*100):0}%</div><div style="font-size:11px;color:var(--mut)">Siegquote</div></div>
    </div>
  </div>`;

  // Match-Liste
  html+=`<div class="section-card"><h3>Letzte Matches</h3>`;
  const lastM=[...matches].sort((a,b)=>b.date.localeCompare(a.date)).slice(0,10);
  html+=`<div style="border-radius:var(--r-lg);overflow:hidden;margin:0 -2px">`;
  lastM.forEach((m, idx)=>{
    const ks=buildMatchKeyStats(m);
    const isWin=m.result&&m.result.startsWith(m.playerA.name);
    const sA=m.sets.filter(s=>s.score[0]>s.score[1]&&isSetOver(s.score[0],s.score[1])).length;
    const sB=m.sets.filter(s=>s.score[0]<s.score[1]&&isSetOver(s.score[0],s.score[1])).length;
    html+=`<div class="match-list-item" data-open-match="${idx}" style="cursor:pointer" title="Bericht öffnen">
      <div class="mli-result ${isWin?"win":"loss"}">${sA}:${sB}</div>
      <div class="mli-info">
        <div class="mli-names">vs ${esc(m.playerB.name)}${m.tournament?` <span style="font-weight:400;color:var(--mut)">· ${esc(m.tournament)}</span>`:""}</div>
        <div class="mli-meta">${fmtDate(m.date)} · ${esc(m.playerA.name)}</div>
        <div class="mli-stats">
          ${!isNaN(ks.serveEff)?`<span class="mli-stat ${statCls(ks.serveEff,.65,.45)}">AS ${pct(ks.serveEff)}</span>`:""}
          ${!isNaN(ks.receiveStab)?`<span class="mli-stat ${statCls(ks.receiveStab,.65,.45)}">AN ${pct(ks.receiveStab)}</span>`:""}
          ${!isNaN(ks.rallyQual)?`<span class="mli-stat ${statCls(ks.rallyQual,.60,.40)}">R ${pct(ks.rallyQual)}</span>`:""}
        </div>
      </div>
      <span style="color:var(--mut);font-size:16px;flex-shrink:0">›</span>
    </div>`;
  });
  html+=`</div>`;
  if(matches.length>10)html+=`<p style="font-size:11.5px;color:var(--mut);margin-top:8px;padding:0 2px">+${matches.length-10} weitere</p>`;
  html+=`</div>`;

  el.innerHTML=html;
}

function buildSparklineSVG(vals,good,ok){
  const W=160,H=28,PAD=4;
  const clean=vals.map(v=>isNaN(v)?null:v);
  const defined=clean.filter(v=>v!==null);
  if(!defined.length)return`<svg viewBox="0 0 ${W} ${H}" style="flex:1;height:${H}px"></svg>`;
  const min=Math.min(...defined,0),max=Math.max(...defined,1);
  const toY=v=>v===null?null:PAD+(1-(v-min)/(max-min||1))*(H-PAD*2);
  const toX=i=>PAD+(i/(vals.length-1||1))*(W-PAD*2);
  let path="";
  vals.forEach((v,i)=>{const y=toY(v);if(y===null)return;path+=(path?"L":"M")+`${toX(i).toFixed(1)},${y.toFixed(1)}`;});
  const lastI=vals.length-1-[...vals].reverse().findIndex(v=>v!==null&&!isNaN(v));
  const dotY=toY(vals[lastI]);
  const lastDef=defined[defined.length-1];
  const dotColor=lastDef>=good?"var(--kraft)":lastDef>=ok?"var(--warm)":"var(--red)";
  const goodY=toY(good).toFixed(1);
  return`<svg viewBox="0 0 ${W} ${H}" style="flex:1;height:${H}px">
    <line x1="${PAD}" y1="${goodY}" x2="${W-PAD}" y2="${goodY}" stroke="rgba(16,185,129,.25)" stroke-width="1" stroke-dasharray="3 2"/>
    ${path?`<path d="${path}" fill="none" stroke="var(--acc)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`:""}
    ${dotY!==null?`<circle cx="${toX(lastI).toFixed(1)}" cy="${dotY.toFixed(1)}" r="3.5" fill="${dotColor}"/>`:""}
  </svg>`;
}
/* ---- Geplant-Tab ---- */
function renderGeplant(){
  const el=document.getElementById("geplantContent");if(!el)return;
  const draftList=lsGet("ttk_plan_drafts",[]);
  const todayIso=today();
  const future=draftList.filter(d=>d.date>=todayIso).sort((a,b)=>a.date.localeCompare(b.date));
  const past=draftList.filter(d=>d.date<todayIso).sort((a,b)=>b.date.localeCompare(a.date));
  if(!draftList.length){
    el.innerHTML=`<div class="stat-empty">Noch keine Einheiten vorgemerkt.<br><br>Erstelle einen Plan und klicke <b>Vormerken</b> um ihn hier zu speichern.</div>`;
    return;
  }
  function planCard(d,idx,isPast){
    const parts=[];
    for(const mod in MODS)if(d.sel[mod]?.length)parts.push(MODS[mod].name+": "+d.sel[mod].map(it=>byId(it.id)?.title||it.id).join(", "));
    return`<div class="planned-item${isPast?" past":""}">
      <div class="pd">${fmtDate(d.date)}${isPast?` <span style="font-size:10px;color:var(--mut)">(vergangen)</span>`:""}</div>
      <div class="ps">${esc(parts.join(" · "))}</div>
      <div class="pb">
        <button class="btn secondary" data-loadplan="${idx}" style="padding:5px 11px;font-size:12.5px">Laden</button>
        <button class="btn danger" data-delplan="${idx}" style="padding:5px 11px;font-size:12.5px">Löschen</button>
      </div>
    </div>`;
  }
  let html="";
  if(future.length){html+=`<div class="section-label">Geplant</div>`+future.map((d)=>planCard(d,draftList.indexOf(d),false)).join("");}
  if(past.length){html+=`<div class="section-label muted" style="margin-top:16px">Vergangene Pläne</div>`+past.map((d)=>planCard(d,draftList.indexOf(d),true)).join("");}
  el.innerHTML=html;
}

/* ---- Einstellungen-Tab init ---- */
function initSettingsTab(){
  renderPlayerListSettings();
  const setClub = document.getElementById("setClub");
  if(setClub) setClub.value = SETTINGS.club||"";

  const wEl=document.getElementById("setWeights");
  const WEIGHT_LABELS={gap:"Lücke (nicht trainiert)",balance:"Themen-Balance",progression:"Progression (fast frei)",phase:"Phasen-Sinnhaftigkeit"};
  if(wEl){
    wEl.innerHTML=Object.keys(DEFAULT_WEIGHTS).map(k=>`
      <div class="weight-row">
        <span class="wname">${esc(WEIGHT_LABELS[k]||k)}</span>
        <input type="range" min="0" max="100" step="5" data-weight="${k}" value="${SETTINGS.weights[k]??DEFAULT_WEIGHTS[k]}">
        <span class="wval" id="wval-${k}">${SETTINGS.weights[k]??DEFAULT_WEIGHTS[k]}</span>
      </div>`).join("");
  }
  const bEl=document.getElementById("setBudgets");
  if(bEl){
    bEl.innerHTML=Object.keys(MODS).map(mod=>`
      <div class="budget-row">
        <span class="bdot" style="background:${MODS[mod].color}"></span>
        <span class="bname">${MODS[mod].name}</span>
        <input type="number" min="0" max="180" step="5" data-budget="${mod}" value="${budget(mod)}" class="field">
        <span style="font-size:12px;color:var(--mut)">min</span>
      </div>`).join("");
    updateBudgetSum();
  }
}

function saveSettingsFromTab(){
  const clubEl=document.getElementById("setClub");
  if(clubEl) SETTINGS.club=(clubEl.value.trim()||"TV Bonn-Geislar");
  document.querySelectorAll("[data-budget]").forEach(i=>{
    SETTINGS.budgets[i.dataset.budget]=Math.max(0,Math.min(180,parseInt(i.value)||0));
  });
  document.querySelectorAll("[data-weight]").forEach(i=>{
    SETTINGS.weights[i.dataset.weight]=Math.max(0,Math.min(100,parseInt(i.value)||0));
  });
  saveSettings();
  render();
  toast("Einstellungen gespeichert");
}

/* Override the old saveSettingsForm with the tab version */
function saveSettingsForm(){
  saveSettingsFromTab();
}

/* ---- Event: Loadplan/Delplan in Geplant ---- */
document.addEventListener("click",e=>{
  const t=e.target.closest("[data-loadplan],[data-delplan]");
  if(!t)return;
  if(t.dataset.loadplan!==undefined){
    const draftList=lsGet("ttk_plan_drafts",[]);
    const d=draftList[parseInt(t.dataset.loadplan)];
    if(d){state={date:d.date,sel:JSON.parse(JSON.stringify(d.sel))};switchTab("planen");render();toast("Plan geladen – Datum prüfen");}
  }
  if(t.dataset.delplan!==undefined){
    const draftList=lsGet("ttk_plan_drafts",[]);
    draftList.splice(parseInt(t.dataset.delplan),1);
    lsSet("ttk_plan_drafts",draftList);
    renderGeplant();
  }
});

/* ---- Saisonbericht aus Auswerten-Tab ---- */
document.getElementById("seasonPrintBtn").onclick=function(){
  renderAuswerten();
  const statsEl=document.getElementById("statsContent");
  if(!statsEl||!statsEl.innerHTML)return;
  const sorted=[...trainLog].sort((a,b)=>a.date.localeCompare(b.date));
  const from=sorted.length?fmtDate(sorted[0].date):"–";
  const to=sorted.length?fmtDate(sorted[sorted.length-1].date):"–";
  const win=window.open("","_blank","width=800,height=600");
  if(!win)return;
  win.document.write(`<!DOCTYPE html><html lang="de"><head><meta charset="UTF-8">
<title>TT-Baukasten Saisonbericht ${esc(SETTINGS.club||"")}</title>
<style>
body{font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',Arial,sans-serif;margin:0;padding:20px;color:#000;font-size:12px}
h1{font-size:18px;font-weight:800;margin-bottom:4px}
.meta{color:#555;margin-bottom:16px;font-size:11px}
h3{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid #ddd;padding-bottom:4px;margin:16px 0 10px}
.ampel-row{display:flex;align-items:center;gap:10px;margin-bottom:6px;font-size:11px}
.albl{width:120px;flex-shrink:0;display:flex;align-items:center;gap:5px}
.ampel-dot{display:inline-block;width:7px;height:7px;border-radius:50%;-webkit-print-color-adjust:exact;print-color-adjust:exact}
.abar-wrap{flex:1;height:4px;background:#eee;border-radius:2px;overflow:hidden}
.abar{height:100%;border-radius:2px;-webkit-print-color-adjust:exact;print-color-adjust:exact}
.aval{font-size:10px;width:40px;text-align:right;font-weight:700}
.milestone-item{display:flex;gap:8px;padding:4px 0;border-bottom:1px solid #eee;font-size:11px}
.mi-date{width:60px;color:#666;flex-shrink:0}
.mi-badge{font-size:9px;font-weight:700;padding:1px 5px;border-radius:10px;background:#f0e6ff;color:#6b0ac9;-webkit-print-color-adjust:exact;print-color-adjust:exact}
.season-cmp{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:8px}
.season-col{border:1px solid #ddd;border-radius:4px;padding:8px}
.sc-head{font-size:9px;text-transform:uppercase;font-weight:700;color:#888;margin-bottom:6px;letter-spacing:.06em}
</style></head><body>
<h1>Saisonbericht ${esc(SETTINGS.club||"")}</h1>
<div class="meta">Zeitraum: ${from} – ${to} · ${trainLog.length} Einheiten gesamt · erstellt mit TT-Baukasten V0.10 © Justin Jungk</div>`);
  win.document.write(statsEl.innerHTML);
  win.document.write(`</body></html>`);
  win.document.close();
  win.onload=()=>win.print();
};

/* ---- Settings speichern binding ---- */
document.getElementById("setSave").onclick=saveSettingsFromTab;
document.getElementById("setReset").onclick=()=>{
  SETTINGS.budgets={...DEFAULT_BUDGETS};
  SETTINGS.weights={...DEFAULT_WEIGHTS};
  initSettingsTab();
  toast("Zurückgesetzt");
};

/* ---- Backup in Settings ---- */
/* ---- Backup Export (unified) ---- */
function exportBackup(){
  const data=JSON.stringify({history:trainLog,custom,settings:SETTINGS},null,2);
  const blob=new Blob([data],{type:"application/json"});
  const a=document.createElement("a");a.href=URL.createObjectURL(blob);
  a.download="tt-baukasten-backup-"+(SETTINGS.club||"").replace(/\s+/g,"-")+"-"+new Date().toISOString().slice(0,10)+".json";
  a.click();URL.revokeObjectURL(a.href);
}
document.getElementById("expBtn").onclick=exportBackup;
document.getElementById("expBtnHist").onclick=exportBackup;
document.getElementById("impBtn").onclick=()=>document.getElementById("impFile").click();
document.getElementById("impFile").addEventListener("change",e=>{
  handleImportFile(e.target.files[0],()=>{render();initSettingsTab();});
  e.target.value="";
});

/* ---- Backup in History Modal (duplicate) ---- */
/* expBtnHist: see exportBackup() above */
document.getElementById("impBtnHist").onclick=()=>document.getElementById("impFileHist").click();
document.getElementById("impFileHist").addEventListener("change",e=>{
  handleImportFile(e.target.files[0],()=>{render();renderHistory();});
  e.target.value="";
});

